# =============================================================================
# Lar dos Anjos Pet — variáveis de exemplo (desenvolvimento local)
# Copie para .env e preencha. NUNCA commite .env com secrets reais.
# Produção Hostinger: use deploy/hostinger-env-*.example + hPanel.
# =============================================================================

# MySQL — codifique '@' na senha como %40 na DATABASE_URL
DATABASE_URL="mysql://root:changeme_local%40password@localhost:3306/lardosanjos"

# Redis (local ou externo; Hostinger Business exige Redis externo)
REDIS_URL="redis://localhost:6379"

# API
PORT=4000
NODE_ENV=development
APP_ENV=local
API_URL="http://localhost:4000"

# URLs das aplicações
WEB_URL="http://localhost:3000"
ADMIN_URL="http://localhost:3001"
APP_URL="http://localhost:3000"
CORS_ORIGINS="http://localhost:3000,http://localhost:3001"
ALLOWED_ORIGINS="http://localhost:3000,http://localhost:3001"

# JWT — gere valores fortes em produção (openssl rand -base64 48)
JWT_SECRET="change-me-jwt-secret-min-32-chars"
JWT_REFRESH_SECRET="change-me-refresh-secret-min-32-chars"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# MFA admin (mín. 32 caracteres)
MFA_ENCRYPTION_KEY="change-me-mfa-encryption-key-min-32-chars"

# Seed admin (somente primeira implantação)
SEED_ADMIN_NAME="Administrador Master"
SEED_ADMIN_EMAIL="admin@lardosanjos.online"
SEED_ADMIN_PASSWORD="change-me-strong-password"

# Asaas sandbox (produção: https://api.asaas.com/v3)
ASAAS_API_URL="https://sandbox.asaas.com/api/v3"
ASAAS_API_KEY="your-asaas-sandbox-api-key"
ASAAS_WEBHOOK_SECRET="your-asaas-webhook-secret"
ASAAS_ENVIRONMENT="sandbox"
ASAAS_TIMEOUT_MS="15000"
ASAAS_MAX_RETRIES="2"
ASAAS_RETRY_DELAY_MS="400"

# Cloudflare R2 (comprovantes — bucket privado para uploads sensíveis)
CLOUDFLARE_R2_ACCOUNT_ID=""
CLOUDFLARE_R2_ACCESS_KEY_ID=""
CLOUDFLARE_R2_SECRET_ACCESS_KEY=""
CLOUDFLARE_R2_BUCKET="lardosanjos-dev"
CLOUDFLARE_R2_PUBLIC_URL=""

# E-mail
RESEND_API_KEY=""
EMAIL_FROM="noreply@lardosanjos.online"

# Sentry (opcional)
SENTRY_DSN=""
SENTRY_ENVIRONMENT="development"
SENTRY_TRACES_SAMPLE_RATE="0.1"

# Frontend (apps/web — também configurar no hPanel antes do build)
# NEXT_PUBLIC_API_URL="http://localhost:4000/api/v1"
# NEXT_PUBLIC_APP_URL="http://localhost:3000"
# NEXT_PUBLIC_SITE_NAME="Lar dos Anjos Pet"

# Frontend (apps/admin)
# NEXT_PUBLIC_API_URL="http://localhost:4000/api/v1"
# NEXT_PUBLIC_ADMIN_URL="http://localhost:3001"
