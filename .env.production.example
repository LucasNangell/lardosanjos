# =============================================================================
# Lar dos Anjos Pet — Variáveis de PRODUÇÃO (exemplo, sem secrets reais)
# Copie para .env.production no servidor e preencha com valores seguros.
# NUNCA commite .env.production nem reutilize senhas de desenvolvimento local.
# =============================================================================

APP_ENV=production
NODE_ENV=production

# --- Domínios ---
WEB_URL=https://lardosanjos.online
ADMIN_URL=https://admin.lardosanjos.online
APP_URL=https://lardosanjos.online
API_URL=https://api.lardosanjos.online
CORS_ORIGINS=https://lardosanjos.online,https://admin.lardosanjos.online
ALLOWED_ORIGINS=https://lardosanjos.online,https://admin.lardosanjos.online

# --- API ---
PORT=4000

# --- MySQL (aplicação — usuário com permissões mínimas, NÃO root) ---
# Codifique '@' na senha como %40 na URL.
DATABASE_URL=mysql://lardosanjos_app:CHANGE_ME_STRONG_PASSWORD@mysql:3306/lardosanjos

# Provisionamento do container MySQL (docker-compose.prod.yml)
MYSQL_DATABASE=lardosanjos
MYSQL_APP_USER=lardosanjos_app
MYSQL_APP_PASSWORD=CHANGE_ME_STRONG_APP_PASSWORD
MYSQL_ROOT_PASSWORD=CHANGE_ME_STRONG_ROOT_PASSWORD

# --- Redis ---
REDIS_URL=redis://redis:6379

# --- JWT / MFA (gere com: openssl rand -base64 48) ---
JWT_SECRET=CHANGE_ME_JWT_SECRET_MIN_32_CHARS
JWT_REFRESH_SECRET=CHANGE_ME_REFRESH_SECRET_MIN_32_CHARS
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
MFA_ENCRYPTION_KEY=CHANGE_ME_MFA_KEY_MIN_32_CHARS

# --- Seed inicial (apenas primeira implantação; remova senha após seed) ---
SEED_ADMIN_NAME=Administrador Master
SEED_ADMIN_EMAIL=admin@lardosanjos.online
SEED_ADMIN_PASSWORD=CHANGE_ME_ONE_TIME_ADMIN_PASSWORD

# --- Asaas PRODUÇÃO ---
ASAAS_API_URL=https://api.asaas.com/v3
ASAAS_API_KEY=your-asaas-production-api-key
ASAAS_WEBHOOK_SECRET=your-asaas-webhook-secret-production
ASAAS_ENVIRONMENT=production
ASAAS_TIMEOUT_MS=15000
ASAAS_MAX_RETRIES=2
ASAAS_RETRY_DELAY_MS=400

# --- Cloudflare R2 (uploads públicos/privados) ---
CLOUDFLARE_R2_ACCOUNT_ID=
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
CLOUDFLARE_R2_BUCKET=lardosanjos-prod
CLOUDFLARE_R2_PUBLIC_URL=https://assets.lardosanjos.online

# --- Backup MySQL → R2 (bucket PRIVADO, separado dos assets) ---
BACKUP_R2_BUCKET=lardosanjos-backups-private
BACKUP_R2_PREFIX=mysql-backups
BACKUP_INTERVAL_HOURS=12
BACKUP_RETENTION_DAYS=30
MYSQL_BACKUP_HOST=mysql
MYSQL_BACKUP_PORT=3306
MYSQL_BACKUP_USER=lardosanjos_backup
MYSQL_BACKUP_PASSWORD=CHANGE_ME_BACKUP_USER_PASSWORD
MYSQL_BACKUP_DATABASE=lardosanjos

# Restore de teste (homologação)
MYSQL_RESTORE_HOST=mysql
MYSQL_RESTORE_PORT=3306
MYSQL_RESTORE_USER=lardosanjos_app
MYSQL_RESTORE_PASSWORD=CHANGE_ME_STRONG_APP_PASSWORD
MYSQL_RESTORE_DATABASE=lardosanjos

# --- E-mail (Resend) ---
RESEND_API_KEY=
EMAIL_FROM=noreply@lardosanjos.online

# --- Sentry ---
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_RELEASE=
SENTRY_TRACES_SAMPLE_RATE=0.1

# --- Frontend (Vercel — configurar nos projetos web/admin) ---
# NEXT_PUBLIC_API_URL=https://api.lardosanjos.online/api/v1
# NEXT_PUBLIC_APP_URL=https://lardosanjos.online
# NEXT_PUBLIC_ADMIN_URL=https://admin.lardosanjos.online
# NEXT_PUBLIC_SENTRY_DSN=
